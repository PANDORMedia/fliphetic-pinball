{
  "_comment": "HETIC Pinball button map — the cabinet's 9 buttons. Single source of truth, shared by the ESP32 firmware (reads `gpio`) and the game (maps button `id` -> `action`). `action` is one of flipperLeft, flipperRight, plunger, start, nudge — or null for a button the game does not use. `keys` are KeyboardEvent.code values so the game stays playable on a plain keyboard. If you rewire, edit this file AND the table in firmware/src/main.cpp.",
  "device": "esp32",
  "poll_hz": 250,
  "debounce_ms": 8,
  "buttons": [
    {
      "id": "black-left",
      "label": "Black Left",
      "gpio": 16,
      "active_low": true,
      "action": "flipperLeft",
      "keys": ["ShiftLeft", "KeyA", "ArrowLeft"]
    },
    {
      "id": "white-left",
      "label": "White Left",
      "gpio": 4,
      "active_low": true,
      "action": "start",
      "keys": ["Enter", "KeyS"]
    },
    {
      "id": "front-left-green",
      "label": "Front Left Green",
      "gpio": 17,
      "active_low": true,
      "action": null,
      "keys": []
    },
    {
      "id": "front-left-yellow",
      "label": "Front Left Yellow",
      "gpio": 18,
      "active_low": true,
      "action": null,
      "keys": []
    },
    {
      "id": "front-left-red",
      "label": "Front Left Red",
      "gpio": 19,
      "active_low": true,
      "action": null,
      "keys": []
    },
    {
      "id": "black-right",
      "label": "Black Right",
      "gpio": 13,
      "active_low": true,
      "action": "flipperRight",
      "keys": ["ShiftRight", "KeyL", "ArrowRight"]
    },
    {
      "id": "white-right",
      "label": "White Right",
      "gpio": 25,
      "active_low": true,
      "action": "nudge",
      "keys": ["ArrowDown", "KeyN"]
    },
    {
      "id": "front-white",
      "label": "Front White",
      "gpio": 33,
      "active_low": true,
      "action": null,
      "keys": []
    },
    {
      "id": "plunger",
      "label": "Plunger",
      "gpio": 32,
      "active_low": true,
      "action": "plunger",
      "keys": ["Space"]
    }
  ]
}
